public class Basic {
    private String name;

    public Basic(String name) {
        this.name = name;
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        this.name = name;
    }

    @Override
    public String toString() {
        return "Basic{name='" + name + "'}";
    }
}
